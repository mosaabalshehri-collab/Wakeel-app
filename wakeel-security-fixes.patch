+# ===========================================================================
+# متغيرات البيئة لتطبيق وكيل — انسخ هذا الملف إلى .env.local واضبط القيم
+# cp .env.example .env.local
+# ===========================================================================
+
+# سر توقيع الـ JWT — إلزامي في الإنتاج (32 حرفاً على الأقل).
+# التطبيق يرفض الإقلاع في الإنتاج بدون قيمة صالحة هنا.
+# توليد قيمة عشوائية قوية:  openssl rand -hex 32
+JWT_SECRET=
+
+# مفتاح خدمة Resend لإرسال رسائل تأكيد البريد واسترجاع كلمة المرور.
+# اتركه فارغاً أثناء التطوير: ستُطبع الرسائل في الطرفية بدل إرسالها.
+RESEND_API_KEY=
+
+# عنوان المُرسِل الظاهر في الرسائل (يتطلب نطاقاً موثّقاً في Resend).
+EMAIL_FROM="وكيل <onboarding@resend.dev>"
+
+# فرض تأكيد البريد قبل الإجراءات الكاتبة (إنشاء وكالة، رفع ملف).
+# true في الإنتاج، false أثناء التطوير المحلي بدون خدمة بريد.
+REQUIRE_EMAIL_VERIFICATION=false
+
+# الثقة برؤوس البروكسي (x-forwarded-for) في تحديد IP لأغراض الـ
+# rate limiting. فعّله (true) فقط خلف بروكسي/منصة موثوقة تعيد كتابة
+# الرأس (مثل Vercel). اتركه false على خادم مكشوف لمنع تزوير IP.
+TRUST_PROXY=false
+
+# الحد الأقصى لعدد الوكالات النشطة لكل مستخدم.
+MAX_POAS_PER_USER=500
